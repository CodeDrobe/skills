  "exportedAt": "2026-07-15T20:07:49.232Z",
  "manifest": {
    "schemaVersion": 1,
    "id": "dilraba-rose",
    "displayName": "Dilraba Rose / 迪丽热巴",
    "version": "1.0.0",
    "css": "theme.css",
    "art": "dilraba-rose-hero.png",
    "copy": {
      "brandTitle": "迪丽热巴专属定制皮肤",
      "brandSubtitle": "Codex App 玫瑰限定版 ✦",
      "signature": "Dilraba Dilmurat ♡",
      "tagline": "与热巴一起，用灵感创造无限可能 ♡",
      "projectPrefix": "选择项目 · ",
      "projectLabel": "♡  选择项目",
      "ribbon": "🌹"
    },
    "baseTheme": {
      "mode": "light",
      "codeTheme": "codex",
      "accent": "#B85F6C",
      "contrast": 78,
      "ink": "#38292C",
      "surface": "#FBF7F3",
      "opaqueWindows": true,
      "fonts": {
        "windowsCode": "Cascadia Code",
        "windowsUi": "Microsoft YaHei UI",
        "macCode": "SF Mono",
        "macUi": "PingFang SC"
      },
      "semanticColors": {
        "diffAdded": "#CFE7D7",
        "diffRemoved": "#F1C7CB",
        "skill": "#C87582"
      }
    }
  },
  "css": ":root.codedrobe-codex-skin {\n  color-scheme: light !important;\n  --dream-ink: #38292c;\n  --dream-purple: #9c4f5b;\n  --dream-violet: #b85f6c;\n  --dream-pink: #c87582;\n  --dream-blush: #f8ecec;\n  --dream-pearl: rgba(255, 253, 250, .96);\n  --dream-line: rgba(184, 95, 108, .30);\n}\n\nhtml.codedrobe-codex-skin body {\n  background:\n    radial-gradient(circle at 86% 4%, rgba(229, 184, 187, .24), transparent 24%),\n    radial-gradient(circle at 16% 10%, rgba(241, 213, 211, .22), transparent 28%),\n    linear-gradient(135deg, #fdfaf7 0%, #fbf7f3 52%, #f7eeee 100%) !important;\n  color: var(--dream-ink) !important;\n  font-family: -apple-system, BlinkMacSystemFont, \"SF Pro Text\", \"PingFang SC\", \"Microsoft YaHei UI\", \"Microsoft YaHei\", system-ui, sans-serif !important;\n}\n\nhtml.codedrobe-codex-skin body::before {\n  content: \"\";\n  position: fixed;\n  inset: 0;\n  z-index: 0;\n  pointer-events: none;\n  opacity: .16;\n  background-image:\n    radial-gradient(circle, rgba(255,255,255,.98) 0 1px, transparent 2px),\n    radial-gradient(circle, rgba(184,95,108,.48) 0 1px, transparent 2px);\n  background-position: 0 0, 23px 31px;\n  background-size: 53px 53px, 67px 67px;\n}\n\nhtml.codedrobe-codex-skin aside.app-shell-left-panel {\n  background:\n    linear-gradient(180deg, rgba(255,253,250,.99), rgba(250,241,239,.98)) !important;\n  border: 1px solid rgba(184, 95, 108, .24) !important;\n  border-left: 0 !important;\n  border-radius: 0 20px 20px 0 !important;\n  box-shadow: 10px 0 32px rgba(91, 52, 57, .08), inset -1px 0 rgba(255,255,255,.9) !important;\n  backdrop-filter: none !important;\n  color: var(--dream-ink) !important;\n}\n\nhtml.codedrobe-codex-skin aside.app-shell-left-panel nav {\n  background: transparent !important;\n}\n\nhtml.codedrobe-codex-skin aside.app-shell-left-panel button {\n  color: #49383b !important;\n  transition: transform .16s ease, background .16s ease, box-shadow .16s ease !important;\n}\n\nhtml.codedrobe-codex-skin aside.app-shell-left-panel button:hover {\n  background: linear-gradient(90deg, rgba(244,219,218,.74), rgba(251,242,238,.82)) !important;\n  box-shadow: inset 0 0 0 1px rgba(184,95,108,.18) !important;\n  transform: translateX(1px);\n}\n\nhtml.codedrobe-codex-skin aside.app-shell-left-panel button[aria-label^=\"切换模式\"] {\n  background: transparent !important;\n  border-color: transparent !important;\n  font-family: Georgia, \"Times New Roman\", serif !important;\n  font-size: 20px !important;\n  font-weight: 700 !important;\n  color: #9c4f5b !important;\n  text-shadow: 0 2px 10px rgba(184,95,108,.16);\n}\n\nhtml.codedrobe-codex-skin aside.app-shell-left-panel button[aria-label^=\"切换模式\"]::after {\n  content: \"✦\";\n  margin-left: 2px;\n  color: #c87582;\n}\n\nhtml.codedrobe-codex-skin aside.app-shell-left-panel [class~=\"bg-token-list-hover-background\"],\nhtml.codedrobe-codex-skin aside.app-shell-left-panel [aria-current=\"page\"] {\n  background: linear-gradient(90deg, rgba(242,215,216,.88), rgba(251,242,238,.92)) !important;\n  border: 1px solid rgba(184,95,108,.26) !important;\n  box-shadow: 0 4px 16px rgba(91,52,57,.08) !important;\n}\n\nhtml.codedrobe-codex-skin main.main-surface {\n  background:\n    radial-gradient(circle at 88% 8%, rgba(235,199,198,.16), transparent 28%),\n    linear-gradient(180deg, #fffdfb 0%, #fbf7f3 100%) !important;\n  border: 1px solid rgba(184, 95, 108, .20) !important;\n  border-right: 0 !important;\n  border-bottom: 0 !important;\n  border-radius: 20px 0 0 0 !important;\n  box-shadow: inset 0 1px rgba(255,255,255,.95), -8px 0 30px rgba(91,52,57,.06) !important;\n  overflow: hidden !important;\n}\n\nhtml.codedrobe-codex-skin main.main-surface > header.app-header-tint {\n  background:\n    linear-gradient(90deg, rgba(255,253,250,.98), rgba(249,237,235,.92), rgba(244,224,223,.88)) !important;\n  border-bottom: 1px solid rgba(184,95,108,.22) !important;\n  backdrop-filter: none !important;\n}\n\n#codedrobe-codex-skin-chrome {\n  position: fixed;\n  z-index: 31;\n  pointer-events: none;\n  overflow: hidden;\n  border-radius: 20px 0 0 0;\n}\n\n.dream-brand {\n  position: absolute;\n  left: 25px;\n  top: 3px;\n  height: 40px;\n  display: none;\n  align-items: center;\n  gap: 10px;\n  color: #8f4652;\n  text-shadow: 0 1px 0 white;\n}\n\n#codedrobe-codex-skin-chrome.dream-home-shell .dream-brand { display: flex; }\n.dream-brand .dream-note { font-size: 29px; color: #b85f6c; filter: drop-shadow(0 2px 4px rgba(184,95,108,.22)); }\n.dream-brand b { display: block; font-size: 15px; letter-spacing: .04em; }\n.dream-brand small { display: block; margin-top: 1px; color: #9b6a70; font-size: 10px; letter-spacing: .03em; }\n\n.dream-signature {\n  position: absolute;\n  right: 92px;\n  top: 6px;\n  display: none;\n  color: #b85f6c;\n  font: italic 20px/1.2 \"Segoe Script\", \"Comic Sans MS\", cursive;\n  text-shadow: 0 0 8px white, 0 2px 8px rgba(91,52,57,.16);\n  transform: rotate(-3deg);\n}\n#codedrobe-codex-skin-chrome.dream-home-shell .dream-signature { display: block; }\n\n.dream-sparkles { position: absolute; inset: 48px 0 0; opacity: .72; }\n.dream-sparkles i { position: absolute; width: 5px; height: 5px; border-radius: 50%; background: #fff7df; box-shadow: 0 0 10px 3px rgba(194,151,72,.32); }\n.dream-sparkles i::before, .dream-sparkles i::after { content: \"\"; position: absolute; left: 2px; top: -6px; width: 1px; height: 17px; background: linear-gradient(transparent, rgba(255,255,255,.95), transparent); }\n.dream-sparkles i::after { transform: rotate(90deg); }\n.dream-sparkles i:nth-child(1) { left: 7%; top: 11%; }\n.dream-sparkles i:nth-child(2) { left: 31%; top: 5%; opacity: .55; }\n.dream-sparkles i:nth-child(3) { left: 55%; top: 17%; opacity: .82; }\n.dream-sparkles i:nth-child(4) { left: 78%; top: 8%; opacity: .64; }\n.dream-sparkles i:nth-child(5) { left: 92%; top: 27%; opacity: .9; }\n.dream-sparkles i:nth-child(6) { left: 66%; top: 66%; opacity: .48; }\n\n.dream-polaroid {\n  position: absolute;\n  right: 11px;\n  bottom: 74px;\n  width: 116px;\n  height: 150px;\n  display: none;\n  background-image: var(--dream-art);\n  background-size: cover;\n  background-position: 74% center;\n  border: 7px solid rgba(255,253,253,.96);\n  border-bottom-width: 20px;\n  box-shadow: 0 9px 20px rgba(91,52,57,.18), 0 0 0 1px rgba(184,95,108,.22);\n  transform: rotate(-7deg);\n  border-radius: 2px;\n}\n#codedrobe-codex-skin-chrome.dream-home-shell .dream-polaroid { display: block; }\n.dream-polaroid::before { content: \"🌹\"; position: absolute; left: -21px; top: -24px; font-size: 28px; filter: drop-shadow(0 3px 4px rgba(91,52,57,.20)); }\n\n.dream-ribbon {\n  position: absolute;\n  left: 50%;\n  bottom: 68px;\n  display: none;\n  align-items: center;\n  gap: 8px;\n  color: #b85f6c;\n  font-size: 30px;\n  transform: translateX(-50%);\n  filter: drop-shadow(0 4px 5px rgba(91,52,57,.18));\n}\n#codedrobe-codex-skin-chrome.dream-home-shell .dream-ribbon { display: flex; }\n.dream-ribbon span { font-size: 15px; color: #c87582; }\n\nhtml.codedrobe-codex-skin [role=\"main\"] {\n  background: transparent !important;\n  scrollbar-color: rgba(184,95,108,.42) transparent;\n}\n\nhtml.codedrobe-codex-skin .dream-home {\n  --thread-content-max-width: min(950px, calc(100cqw - 44px)) !important;\n  overflow-x: hidden !important;\n}\n\n.dream-home > div:first-child {\n  padding-top: 15px !important;\n  min-height: 100% !important;\n}\n\n.dream-home > div:first-child > div:first-child {\n  flex: 0 0 430px !important;\n  min-height: 430px !important;\n  align-items: flex-start !important;\n  padding-bottom: 0 !important;\n}\n\n.dream-home > div:first-child > div:first-child > div:first-child {\n  position: relative !important;\n  isolation: isolate;\n  width: calc(100% - 44px) !important;\n  max-width: none !important;\n  height: 252px !important;\n  min-height: 252px !important;\n  flex: 0 1 auto !important;\n  padding: 0 !important;\n  border: 1px solid rgba(184,95,108,.34) !important;\n  border-radius: 25px !important;\n  overflow: visible !important;\n  background-image:\n    linear-gradient(90deg, rgba(255,253,250,.04), rgba(200,117,130,.04)),\n    var(--dream-art) !important;\n  background-repeat: no-repeat !important;\n  background-size: 100% 100%, cover !important;\n  background-position: center, center !important;\n  box-shadow: 0 14px 34px rgba(91,52,57,.14), inset 0 0 0 3px rgba(255,255,255,.34) !important;\n}\n\n.dream-home > div:first-child > div:first-child > div:first-child::before {\n  content: \"\";\n  position: absolute;\n  z-index: 0;\n  inset: 0 auto 0 0;\n  width: 62%;\n  border-radius: 23px 0 0 23px;\n  pointer-events: none;\n  background: linear-gradient(90deg, rgba(253,250,247,.98) 0%, rgba(253,250,247,.96) 56%, rgba(253,250,247,.76) 80%, transparent 100%);\n}\n\n.dream-home > div:first-child > div:first-child > div:first-child > div:first-child {\n  position: relative;\n  z-index: 1;\n  height: 100%;\n  align-items: center !important;\n  justify-content: flex-start !important;\n  padding-left: 38px;\n}\n\n.dream-home > div:first-child > div:first-child > div:first-child > div:first-child > div:first-child {\n  width: 54% !important;\n  align-items: flex-start !important;\n  gap: 0 !important;\n}\n\n.dream-home [data-testid=\"home-icon\"] {\n  display: none !important;\n}\n\n.dream-home [data-feature=\"game-source\"] {\n  display: flex !important;\n  flex-direction: column !important;\n  align-items: flex-start !important;\n  justify-content: flex-start !important;\n  max-width: 100% !important;\n  color: #38292c !important;\n  font-size: clamp(20px, 2vw, 30px) !important;\n  line-height: 1.3 !important;\n  font-weight: 750 !important;\n  text-align: left !important;\n  text-shadow: 0 1px 0 rgba(255,255,255,.92);\n  opacity: 1 !important;\n  pointer-events: auto !important;\n}\n\n.dream-home [data-feature=\"game-source\"]::after {\n  content: var(--dream-tagline, \"把灵感写进每一天 ♡\");\n  display: block;\n  margin-top: 13px;\n  color: #714c52;\n  font-size: 15px;\n  line-height: 1.5;\n  font-weight: 500;\n  letter-spacing: .02em;\n}\n\n.dream-home [data-feature=\"game-source\"] button {\n  margin: 0 5px;\n  padding: 2px 9px 3px;\n  border: 1px solid rgba(184,95,108,.30);\n  border-radius: 999px;\n  background: rgba(255,253,250,.72);\n  color: #8f4652 !important;\n  text-decoration-color: rgba(184,95,108,.54) !important;\n  text-underline-offset: 5px;\n  box-shadow: inset 0 0 12px rgba(255,255,255,.72);\n}\n\n.dream-home [data-feature=\"game-source\"] button::before {\n  content: var(--dream-project-prefix, \"选择项目 · \");\n  font-size: .48em;\n  font-weight: 600;\n  vertical-align: middle;\n  opacity: .86;\n}\n\n.dream-home > div:first-child > div:first-child > div:first-child > div:nth-child(2) {\n  left: 14px !important;\n  right: 14px !important;\n  top: 100% !important;\n  margin-top: 13px !important;\n}\n\n.dream-home .group\\/home-suggestions {\n  overflow: visible !important;\n}\n\n.dream-home .group\\/home-suggestions button {\n  position: relative !important;\n  min-height: 126px !important;\n  padding: 14px 13px 12px !important;\n  align-items: stretch !important;\n  justify-content: flex-start !important;\n  text-align: center !important;\n  border: 1px solid rgba(184,95,108,.28) !important;\n  border-radius: 23px !important;\n  background:\n    radial-gradient(circle at 50% 25%, rgba(255,255,255,.98), transparent 34%),\n    linear-gradient(145deg, rgba(255,253,250,.99), rgba(249,237,235,.98)) !important;\n  color: #38292c !important;\n  font-weight: 600 !important;\n  line-height: 1.45 !important;\n  box-shadow: 0 8px 18px rgba(91,52,57,.09), inset 0 0 0 3px rgba(255,255,255,.56) !important;\n  transform: translateY(0);\n  transition: transform .18s ease, box-shadow .18s ease !important;\n}\n\n.dream-home .group\\/home-suggestions button:hover {\n  transform: translateY(-4px) !important;\n  box-shadow: 0 13px 26px rgba(91,52,57,.14), 0 0 0 2px rgba(184,95,108,.12) !important;\n}\n\n.dream-home .group\\/home-suggestions button > span:first-child > span:first-child {\n  width: 38px;\n  height: 38px;\n  display: grid !important;\n  place-items: center;\n  margin: 0 auto;\n  border-radius: 50%;\n  color: white !important;\n  background: linear-gradient(145deg, #d98f98, #b85f6c);\n  box-shadow: 0 0 0 7px rgba(242,215,216,.66), 0 5px 12px rgba(91,52,57,.18);\n}\n.dream-home .group\\/home-suggestions button svg {\n  width: 21px !important;\n  height: 21px !important;\n  color: white !important;\n}\n.dream-home .group\\/home-suggestions button > span:first-child {\n  justify-content: center !important;\n}\n.dream-home .group\\/home-suggestions button > span:last-child {\n  align-items: center !important;\n  text-align: center !important;\n}\n\nhtml.codedrobe-codex-skin .composer-surface-chrome {\n  border: 1px solid rgba(184,95,108,.38) !important;\n  border-radius: 25px !important;\n  background:\n    radial-gradient(circle at 88% 22%, rgba(255,255,255,.96), transparent 24%),\n    linear-gradient(145deg, rgba(255,253,250,.99), rgba(249,237,235,.98)) !important;\n  box-shadow: 0 10px 25px rgba(91,52,57,.12), inset 0 0 0 4px rgba(255,255,255,.50) !important;\n  backdrop-filter: none !important;\n  overflow: visible !important;\n}\n\nhtml.codedrobe-codex-skin .composer-surface-chrome::before {\n  content: \"♡\";\n  position: absolute;\n  left: -13px;\n  top: -13px;\n  z-index: 20;\n  width: 27px;\n  height: 27px;\n  display: grid;\n  place-items: center;\n  border-radius: 50%;\n  color: white;\n  background: linear-gradient(145deg, #d98f98, #b85f6c);\n  box-shadow: 0 4px 12px rgba(91,52,57,.18);\n}\n\n.dream-home div:has(> .horizontal-scroll-fade-mask .group\\/project-selector) {\n  position: relative;\n  padding-top: 28px !important;\n  border: 1px solid rgba(184,95,108,.24);\n  border-bottom: 0;\n  background: linear-gradient(180deg, rgba(255,253,250,.98), rgba(249,237,235,.94)) !important;\n}\n\n.dream-home div:has(> .horizontal-scroll-fade-mask .group\\/project-selector)::before {\n  content: var(--dream-project-label, \"♡  选择项目\");\n  position: absolute;\n  left: 13px;\n  top: 6px;\n  z-index: 2;\n  color: #8f4652;\n  font-size: 13px;\n  font-weight: 700;\n  letter-spacing: .04em;\n  text-shadow: 0 1px white;\n  white-space: nowrap;\n}\n\n.dream-home .group\\/project-selector > button {\n  border-color: rgba(184,95,108,.28) !important;\n  background: linear-gradient(135deg, rgba(255,255,255,.96), rgba(249,237,235,.90)) !important;\n  color: #714c52 !important;\n  box-shadow: 0 3px 10px rgba(91,52,57,.08) !important;\n}\n\nhtml.codedrobe-codex-skin .ProseMirror {\n  color: #38292c !important;\n  caret-color: #b85f6c !important;\n}\n\nhtml.codedrobe-codex-skin button[class~=\"bg-token-foreground\"] {\n  background: linear-gradient(145deg, #c87582, #a84f5c) !important;\n  color: white !important;\n  box-shadow: 0 5px 12px rgba(91,52,57,.20) !important;\n}\n\nhtml.codedrobe-codex-skin article,\nhtml.codedrobe-codex-skin [data-message-author-role] {\n  border-radius: 20px;\n}\n\n@media (max-width: 1120px) {\n  .dream-polaroid { display: none !important; }\n  .dream-ribbon { bottom: 70px; font-size: 25px; }\n  .dream-home { --thread-content-max-width: min(860px, calc(100cqw - 30px)) !important; }\n  .dream-home > div:first-child > div:first-child > div:first-child { width: calc(100% - 28px) !important; }\n}\n\n@media (max-width: 900px) {\n  .dream-signature { display: none !important; }\n  .dream-brand { left: 15px; }\n  .dream-brand b { font-size: 13px; }\n  .dream-home > div:first-child > div:first-child { flex-basis: 396px !important; min-height: 396px !important; }\n  .dream-home > div:first-child > div:first-child > div:first-child { height: 224px !important; min-height: 224px !important; background-size: 100% 100%, cover !important; }\n  .dream-home > div:first-child > div:first-child > div:first-child > div:first-child { padding-left: 26px; }\n  .dream-home > div:first-child > div:first-child > div:first-child > div:first-child > div:first-child { width: 66% !important; }\n  .dream-home [data-feature=\"game-source\"] { font-size: 18px !important; }\n  .dream-home [data-feature=\"game-source\"]::after { font-size: 12px; margin-top: 10px; }\n  .dream-home .group\\/home-suggestions button { min-height: 114px !important; font-size: 12px !important; }\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .dream-sparkles i { animation: none !important; }\n}\n",
  "art": {
    "filename": "dilraba-rose-hero.png",
